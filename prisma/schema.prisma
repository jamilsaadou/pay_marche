generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COLLECTOR
}

enum ExhibitorStatus {
  PENDING
  PARTIAL
  PAID
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  CARD
  BANK_TRANSFER
}

model User {
  id               String            @id @default(cuid())
  fullName         String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(COLLECTOR)
  isActive         Boolean           @default(true)
  payments         Payment[]         @relation("CollectorPayments")
  boothAssignments BoothAssignment[] @relation("AssignedByUser")
  activityLogs     ActivityLog[]     @relation("UserActivityLogs")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Exhibitor {
  id              String          @id @default(cuid())
  referenceNumber String          @unique
  firstName       String?
  lastName        String?
  fullName        String
  email           String?
  companyName     String?
  phone           String?
  age             Int?
  gender          String?
  nationality     String?
  address         String?
  businessRegister String?
  activitySector  String?
  location        String?
  region          String?
  expectedAmount  Decimal         @default(0) @db.Decimal(12, 2)
  totalPaid       Decimal         @default(0) @db.Decimal(12, 2)
  status          ExhibitorStatus @default(PENDING)
  payments        Payment[]
  boothAssignment BoothAssignment?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
}

model Payment {
  id          String        @id @default(cuid())
  exhibitorId String
  collectorId String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(CASH)
  reference   String?
  notes       String?
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())

  exhibitor Exhibitor @relation(fields: [exhibitorId], references: [id], onDelete: Restrict)
  collector User      @relation("CollectorPayments", fields: [collectorId], references: [id], onDelete: Restrict)

  @@index([exhibitorId])
  @@index([collectorId])
  @@index([paidAt])
}

model Booth {
  id         String           @id @default(cuid())
  code       String           @unique
  zone       String?
  isActive   Boolean          @default(true)
  assignment BoothAssignment?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model BoothAssignment {
  id           String   @id @default(cuid())
  exhibitorId  String   @unique
  boothId      String   @unique
  assignedById String?
  assignedAt   DateTime @default(now())

  exhibitor  Exhibitor @relation(fields: [exhibitorId], references: [id], onDelete: Restrict)
  booth      Booth     @relation(fields: [boothId], references: [id], onDelete: Restrict)
  assignedBy User?     @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([assignedAt])
}

model SystemConfig {
  id                   Int      @id @default(1)
  defaultExpectedAmount Decimal  @default(0) @db.Decimal(12, 2)
  minPaymentAmount     Decimal  @default(0) @db.Decimal(12, 2)
  maxPaymentAmount     Decimal  @default(100000000) @db.Decimal(12, 2)
  allowPartialPayments Boolean  @default(true)
  currency             String   @default("XOF")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorName   String?
  actorEmail  String?
  actionKey   String
  actionLabel String
  module      String?
  targetType  String?
  targetId    String?
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User? @relation("UserActivityLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actionKey])
  @@index([actorId])
}
